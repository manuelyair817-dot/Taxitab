{
  "expo": {
    "name": "Taxitab",
    "slug": "TaxitabFinal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.yair2.TaxitabFinal",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "INTERNET",
        "VIBRATE",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermissionMsg": "Taxitab necesita acceso al GPS para monitorear la unidad y detectar accidentes."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
   "extra": {
      "eas": {
        "projectId": "19d884cf-becd-4858-85ab-8af0f4c5f4c4" // <-- BORRA ESTA LÍNEA
      },
      "tomtomKey": "mlOxpfn6qOelhLKtRM49tHwCtkU3nNkT"
    }
  }
}